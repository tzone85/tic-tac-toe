{
  "name": "tic-tac-toe",
  "private": true,
  "version": "1.0.0",
  "description": "Browser tic-tac-toe — TypeScript, Vite, Vitest, Playwright.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
